{
  "extends": "coding-agent",
  "meta": {
    "name": "opencode"
  },
  "filesystem": {
    "read": ["$HOME/.claude"],
    "allow": [
      "$HOME/.config/opencode",
      "$HOME/.local/share/opencode",
      "$HOME/.cache/opencode",
      "$HOME/.local/state/opencode"
    ]
  },
  "network": {
    "block": false
  }
}
